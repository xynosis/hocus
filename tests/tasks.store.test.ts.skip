import { describe, it, expect, beforeEach } from 'vitest'
import { setActivePinia, createPinia } from 'pinia'
import { useTasksStore } from '~/stores/tasks'

describe('tasks store', () => {
  beforeEach(() => {
    setActivePinia(createPinia())
  })

  it('adds a task', () => {
    const store = useTasksStore()
    store.addTask({ title: 'Test task' })
    expect(store.tasks).toHaveLength(1)
    expect(store.tasks[0]!.title).toBe('Test task')
    expect(store.tasks[0]!.status).toBe('todo')
  })

  it('generates a unique id per task', () => {
    const store = useTasksStore()
    store.addTask({ title: 'Task A' })
    store.addTask({ title: 'Task B' })
    expect(store.tasks[0]!.id).not.toBe(store.tasks[1]!.id)
  })

  it('updates a task', () => {
    const store = useTasksStore()
    store.addTask({ title: 'Original' })
    const id = store.tasks[0]!.id
    store.updateTask(id, { title: 'Updated' })
    expect(store.getTaskById(id)?.title).toBe('Updated')
  })

  it('deletes a task', () => {
    const store = useTasksStore()
    store.addTask({ title: 'To delete' })
    const id = store.tasks[0]!.id
    store.deleteTask(id)
    expect(store.tasks).toHaveLength(0)
  })

  it('sets task status', () => {
    const store = useTasksStore()
    store.addTask({ title: 'Task' })
    const id = store.tasks[0]!.id
    store.setTaskStatus(id, 'in_progress')
    expect(store.getTaskById(id)?.status).toBe('in_progress')
  })

  it('sorts in_progress tasks first', () => {
    const store = useTasksStore()
    store.addTask({ title: 'Todo task' })
    store.addTask({ title: 'In progress task' })
    const inProgressId = store.tasks[0]!.id
    store.setTaskStatus(inProgressId, 'in_progress')
    expect(store.sortedTasks[0]!.status).toBe('in_progress')
  })

  it('ignores updateTask for unknown id', () => {
    const store = useTasksStore()
    store.addTask({ title: 'Task' })
    expect(() => store.updateTask('nonexistent', { title: 'X' })).not.toThrow()
    expect(store.tasks[0]!.title).toBe('Task')
  })
})